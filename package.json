{
    "name": "bidagent",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.26.2",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "prepare": "husky",
        "postinstall": "yzcfront-version",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview --port 4173",
        "clean": "rimraf node_modules dist",
        "lint": "eslint . --fix",
        "format": "prettier --write .",
        "type-check": "vue-tsc --build --force",
        "yapi": "npx ytt && pnpm lint",
        "release": "release-it"
    },
    "dependencies": {
        "@element-plus/icons-vue": "^2.3.1",
        "@yzcfront/check-version": "1.2.1",
        "@yzcfront/flexable": "^1.0.1-2",
        "@yzcfront/request": "1.0.27",
        "@yzcfront/runtime-origin": "1.0.4",
        "@yzcfront/ui-base": "3.2.4",
        "axios": "^1.11.0",
        "dayjs": "^1.11.13",
        "element-plus": "^2.14.1",
        "lodash-es": "^4.17.21",
        "nprogress": "^0.2.0",
        "pinia": "^3.0.4",
        "qiankun": "^2.10.16",
        "vite-plugin-qiankun": "^1.0.15",
        "vue": "^3.5.35",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^10.0.1",
        "@release-it/conventional-changelog": "^11.0.1",
        "@tsconfig/node20": "^20.1.6",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^22.10.5",
        "@types/nprogress": "^0.2.3",
        "@typescript-eslint/eslint-plugin": "^8.40.0",
        "@typescript-eslint/parser": "^8.40.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitejs/plugin-vue-jsx": "^5.1.5",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.8.0",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "only-allow": "^1.2.1",
        "postcss-pxtorem": "^6.1.0",
        "prettier": "^3.6.2",
        "release-it": "^20.2.0",
        "rimraf": "^6.1.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "sass": "^1.90.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.40.0",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^32.1.0",
        "vite": "^8.0.16",
        "vite-plugin-checker": "^0.14.1",
        "vite-plugin-meta-env": "^1.0.2",
        "vite-plugin-vue-devtools": "^8.1.2",
        "vue-eslint-parser": "^10.2.0",
        "vue-tsc": "^3.3.4",
        "yapi-to-typescript": "^3.38.0"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,vue}": [
            "npm run lint"
        ]
    },
    "release-it": {
        "git": {
            "commitMessage": "chore: release v${version}"
        },
        "github": {
            "release": false
        },
        "npm": {
            "publish": false
        },
        "plugins": {
            "@release-it/conventional-changelog": {
                "preset": "conventionalcommits",
                "infile": "CHANGELOG.md"
            }
        }
    }
}
