{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": [
        "src/**/*.vue",
        "src/**/*.ts",
        "src/**/*.tsx",
        "./auto-imports.d.ts",
        "./components.d.ts",
        "./typed-router.d.ts",
        "src/types/**/*.d.ts"
    ],
    "compilerOptions": {
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@yzcfront/ui-base/*": ["./node_modules/@yzcfront/ui-base/*"]
        },
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "preserve",
        "allowJs": true,
        "types": [
            "node",
            "element-plus/global",
            "@yzcfront/ui-base/esm/global"
        ]
    }
}
