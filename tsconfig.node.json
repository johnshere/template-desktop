{
    "extends": "@tsconfig/node20/tsconfig.json",
    "include": [
        "vite.config.ts",
        "scripts/**/*.ts"
    ],
    "compilerOptions": {
        "composite": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "types": ["node"]
    }
}
